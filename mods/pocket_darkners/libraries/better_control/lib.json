{
    "id": "better_control",
    "authors": [
        "Elioze",
        "Simbel"    //Helped with the spacing formula.
    ],
    "version": "v3.1.1",
    "engineVer": "v0.10.0",
    "config":{
        "saveAfterModification": false,     //Save keybinds when modifying them.
        "cancelToExit":          false,     //Allow you to press the cancel key to get out of the binding menu.

        "squishLongAssName":     false,     //Wether to squish or truncate long ass name.

        "alwaysShowIndicator":   false,     //Show the dots even when there is no extra keybinds.
        "keyIndex":              false,     //Show "KEY: key_index/last_key_index" instead of dots.
        "smallFontIndicator":    false,     //If the "KEY: key_index/last_key_index" should use a smaller font.

        "bannedKeys": [                     //List of key to hide in the binding menu. (Contains the debug key by default)
            //"id_of_input" ex: up, down, menu, cancel, ... - By default hide the debug keys.
            "console",
            "debug_menu",
            "object_selector",
            "fast_forward",
            "mod_rebind"
        ]
    },

    //Exemple of keybinds and how to set them
    "keybinds": [
        //{   "name": "LONGASSNAMETOTEST",      "id": "test2",      "keys": ["m"], "gamepad": ["gamepad:rightshoulder"],        "hide": false   },
        //{   "name": "Test3",                  "id": "test3",      "keys": ["u"], "gamepad": ["gamepad:back"],                 "hide": false   },
        //{   "name": "Test4",                  "id": "test4",      "keys": ["r"], "gamepad": ["gamepad:start"],                "hide": false   },
    ]
}